# Copy to `.env.local` and fill in real values.

# Convex (https://dashboard.convex.dev) — leave blank until `pnpm exec convex dev` fills them in.
# Never set CONVEX_DEPLOYMENT to placeholders like "placeholder:placeholder" (Convex CLI will error).
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# AI
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# UploadThing (https://uploadthing.com)
UPLOADTHING_TOKEN=

# PostHog (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Future / optional from build pack
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
HCAPTCHA_SECRET=
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
